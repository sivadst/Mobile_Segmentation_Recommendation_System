   "source": [
    "# 📱 Mobile Product Segmentation & Recommendation System\n",
    "## Jupyter Notebook - Complete Analysis\n",
    "\n",
    "This notebook contains the complete end-to-end analysis for the Mobile Product Segmentation project."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Setup & Imports"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import plotly.express as px\n",
    "import sys\n",
    "sys.path.append('../src')\n",
    "\n",
    "from data_preprocessing import preprocess_pipeline\n",
    "from clustering_model import run_clustering_pipeline\n",
    "from recommendation_system import MobileRecommendationSystem\n",
    "\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Data Loading & Preprocessing"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load raw data\n",
    "df_raw = pd.read_csv('../data/mobile_products_raw.csv')\n",
    "print(f'Raw data shape: {df_raw.shape}')\n",
    "df_raw.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run preprocessing pipeline\n",
    "df_processed, scaler, scaled_cols, le_brand, le_country, features = preprocess_pipeline(\n",
    "    '../data/mobile_products_raw.csv',\n",
    "    save_path='../data/mobile_products_processed.csv'\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Exploratory Data Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Statistical summary\n",
    "df_processed.describe()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Brand distribution\n",
    "brand_counts = df_processed['Brand'].value_counts()\n",
    "fig = px.bar(x=brand_counts.index, y=brand_counts.values,\n",
    "             title='Product Distribution by Brand',\n",
    "             labels={'x': 'Brand', 'y': 'Count'})\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Clustering Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run clustering\n",
    "df_clustered, kmeans_model, insights = run_clustering_pipeline(\n",
    "    df_processed, features, n_clusters=4\n",
    ")\n",
    "df_clustered.to_csv('../data/mobile_products_clustered.csv', index=False)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Recommendation System"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize recommendation system\n",
    "rec_sys = MobileRecommendationSystem(df_clustered, features)\n",
    "\n",
    "# Test recommendation by product\n",
    "sample_product = df_clustered.iloc[0]['Product_ID']\n",
    "recs, product = rec_sys.get_recommendations_by_product(sample_product, 5)\n",
    "print(f'Recommendations for {product["Brand"]} {product["Model"]}:')\n",
    "recs"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Business Insights"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cluster summary\n",
    "for c, info in insights.items():\n",
    "    print(f'\nCluster {c}: {info["segment"]}')\n",
    "    print(f'  Products: {info["count"]}')\n",
    "    print(f'  Avg Price: ${info["avg_price"]:.2f}')\n",
    "    print(f'  Top Brands: {info["top_brands"]}')"
   ]
  }
